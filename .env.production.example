# =========================
# NIGELEC BACKEND - PROD EXAMPLE
# =========================
# Do not commit real secrets.
# On Heroku, set these as Config Vars.

APP_NAME=nigelec-backend
ENV=prod

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority
MONGO_DB=nigelec

# JWT
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_MIN=1440

# CORS
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=https://your-frontend.vercel.app,https://your-domain.com
# Optional regex; leave empty if not needed
CORS_ORIGIN_REGEX=

# Optional seeded admin account on startup
ADMIN_PHONE=90000000
ADMIN_PASSWORD=replace_with_strong_password
ADMIN_NAME=Admin
